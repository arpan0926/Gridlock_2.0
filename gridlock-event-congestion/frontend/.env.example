# Gridlock Frontend Environment Configuration
# Copy this file to .env and configure as needed.

# Backend API base URL
# For local development:
VITE_API_BASE_URL=http://127.0.0.1:8000/api

# For the deployed Hugging Face Space backend, uncomment below:
# VITE_API_BASE_URL=https://arpann09-gridlock.hf.space/api

# Map defaults (Bengaluru center)
VITE_MAP_DEFAULT_LAT=12.9716
VITE_MAP_DEFAULT_LNG=77.5946
VITE_MAP_DEFAULT_ZOOM=13
